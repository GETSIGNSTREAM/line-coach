# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://epfxzpemsbeljspfwuwe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT
JWT_SECRET=your-jwt-secret-here

# Toast POS Webhook
TOAST_WEBHOOK_SECRET=your-toast-webhook-bearer-token-here

# Admin
ADMIN_PASSWORD=your-admin-password-here

# Feedback tips (Momos reviews → Claude → kitchen display)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional overrides:
# LC_FEEDBACK_TIPS_MODEL=claude-opus-4-8   # set claude-sonnet-5 / claude-haiku-4-5 to cut cost
# LC_FEEDBACK_MOCK=1                       # dev only: canned reviews instead of the momos table

# Learn mode — Notion Culinary OS sync (admin "Sync from Notion" button)
NOTION_API_KEY=your-notion-integration-secret-here
# Optional: defaults to the Culinary OS parent page; set to point directly
# at the Line Build Guides page or database.
# NOTION_RECIPES_PAGE_ID=...
# LC_RECIPE_SYNC_MODEL=claude-opus-4-8
